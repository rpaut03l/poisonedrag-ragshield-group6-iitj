OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
HUGGINGFACE_TOKEN=hf_...
VLLM_ENDPOINT=http://your-vllm-server:8000/v1

# ---- vLLM (self-hosted OpenAI-compatible server) — optional 4th LLM ----
